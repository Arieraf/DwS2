<!DOCTYPE html>
<html>

<head>
    <title>My Project</title>

    <link rel="stylesheet" href="/css/style.css">
</head>

<body>

    <h1>Edit Project</h1>

    <form action="/project/edit/{{project.id}}" method="POST">

        <label>Project Name</label><br>
        <input type="text" name="projectName" value="{{project.projectName}}">

    <br><br>

    <label>Start Date</label><br>
    <input type="date" name="startDate" value="{{project.startDate}}">

    <br><br>

    <label>End Date</label><br>
    <input type="date" name="endDate" value="{{project.endDate}}">

    <br><br>

    <label>Image</label><br>
    <input type="text" name="image" value="{{project.image}}">

    <br><br>

    <button type="submit">
        Update Project
    </button>

</form>

<br>

<a href="/project">
    Back
</a>

</body>

</html>